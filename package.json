{
  "name": "aveno",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "deploy:backend": "bash scripts/deploy-backend.sh",
    "deploy:frontend": "bash scripts/deploy-frontend.sh",
    "frontend:status": "bash scripts/frontend-service.sh status",
    "frontend:logs": "bash scripts/frontend-service.sh logs",
    "frontend:restart": "bash scripts/frontend-service.sh restart",
    "frontend:stop": "bash scripts/frontend-service.sh stop",
    "frontend:start": "bash scripts/frontend-service.sh start",
    "docker:backend:down": "docker compose -f docker-compose.backend.yml down",
    "docker:backend:logs": "docker compose -f docker-compose.backend.yml logs -f",
    "docker:prod": "docker compose -f docker-compose.prod.yml --env-file .env up --build -d",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down",
    "docker:prod:logs": "docker compose -f docker-compose.prod.yml logs -f"
  },
  "dependencies": {
    "framer-motion": "^12.40.0",
    "jalaali-js": "^2.0.0",
    "lucide-react": "0.468.0",
    "next": "15.5.19",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@types/jalaali-js": "^1.2.0",
    "@types/node": "22.10.2",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "typescript": "5.7.2"
  }
}
