# Copy to .env: cp .env.production.example .env
#
# Hybrid deploy (recommended):
#   npm run deploy:backend   — Docker: PostgreSQL + FastAPI
#   npm i && npm run build && npm run up
#
# Full Docker deploy (alternative):
#   docker compose -f docker-compose.prod.yml --env-file .env up --build -d

# Public URL (CORS + browser) — your server IP or domain
# Examples:
#   http://203.0.113.10:3314
#   https://aveno.example.com
PUBLIC_URL=http://YOUR_SERVER_IP:3314

# Frontend port (Next.js on host)
APP_PORT=3314

# Bind address — 0.0.0.0 = reachable from outside the server
APP_BIND_HOST=0.0.0.0

# Next.js → local API (Docker exposes 8000 on 127.0.0.1)
API_INTERNAL_URL=http://127.0.0.1:8000

# Database
POSTGRES_USER=void
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_DB=void_spirit

# API secret (generate: openssl rand -hex 32)
SECRET_KEY=change-this-secret-key

# JWT session length — 525600 minutes = 1 year
ACCESS_TOKEN_EXPIRE_MINUTES=525600

# npm registry for frontend install (see .npmrc)
NPM_REGISTRY=https://mirror-npm.runflare.com
