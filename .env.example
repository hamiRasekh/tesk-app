# Database
POSTGRES_USER=void
POSTGRES_PASSWORD=void
POSTGRES_DB=void_spirit
DATABASE_URL=postgresql://void:void@localhost:5432/void_spirit

# API
SECRET_KEY=change-me-in-production
# JWT lifetime in minutes (default 525600 = 365 days)
ACCESS_TOKEN_EXPIRE_MINUTES=525600
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend (Next.js server-side proxy to FastAPI)
API_INTERNAL_URL=http://127.0.0.1:8000

# --- Production (docker-compose.prod.yml) ---
# PUBLIC_URL=http://YOUR_SERVER_IP:3314
# APP_PORT=3314
# USE_IRAN_MIRRORS=true
# NPM_REGISTRY=https://mirror-npm.runflare.com
